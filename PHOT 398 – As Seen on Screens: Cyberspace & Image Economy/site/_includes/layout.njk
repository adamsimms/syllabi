<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="robots" content="index,follow">
  <title>{{ title }} — {{ courseTitle }}</title>
  <meta name="description" content="{{ title }} — PHOT 398 course archive by Adam Simms.">
  <link rel="stylesheet" href="assets/cargo/fonts.css">
  <link rel="stylesheet" href="assets/cargo/platform.css">
  <link rel="stylesheet" href="assets/cargo/member.css">
  <link rel="stylesheet" href="assets/cargo/local-nav.css">
  <link rel="stylesheet" href="assets/cargo/local-content.css">
  <link rel="stylesheet" href="assets/cargo/static-overrides.css">
</head>
<body data-css-preset data-predefined-style="true">
  <div class="main_container">
    <div data-view="pinned_top" class="pinned pinned_top">
      <div class="page_container overlay accommodate fixed exclude_desktop" local-style="21252715">
        <div class="page container container_width clearfix">
          <bodycopy class="bodycopy content content_padding">
            <div class="page_content clearfix">
              <projectcontent><b><a href="index.html">PHOT398 A</a></b></projectcontent>
            </div>
          </bodycopy>
        </div>
        <div class="page_background"></div>
      </div>
      <div class="page_container overlay fixed exclude_mobile" local-style="21252714">
        <div class="page container container_width clearfix">
          <bodycopy class="bodycopy content content_padding">
            <div class="page_content clearfix">
              <projectcontent>{% include "nav.njk" %}</projectcontent>
            </div>
          </bodycopy>
        </div>
        <div class="page_background"></div>
      </div>
    </div>

    <div class="content_container">
      <div data-view="Content" class="page_container" local-style="21258661">
        <div class="page container container_width">
          <bodycopy class="bodycopy content content_padding">
            <div class="page_content clearfix">
              <projectcontent>{{ pageContent | safe }}</projectcontent>
            </div>
          </bodycopy>
        </div>
        <div class="page_background"></div>
      </div>
    </div>
  </div>
</body>
</html>
